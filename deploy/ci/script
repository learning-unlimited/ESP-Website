#!/bin/bash
set -euf -o pipefail

if [ "$CI_JOB" = "test" ]; then
    cd esp
    printenv
    ./manage.py shell -c "from django.conf import settings; print('ACTIVE DATABASES SETTING:', settings.DATABASES)"
    ./manage.py collectstatic --noinput -v 0
    ./manage.py migrate
    coverage run --source=. ./manage.py test -v 2
    coverage xml
elif [ "$CI_JOB" = "lint" ]; then
    deploy/lint
else
    echo "Unknown CI_JOB: $CI_JOB"
    exit 1
fi
